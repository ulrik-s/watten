{
  "name": "watten-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm": "wasm-pack build --target web --out-dir frontend/pkg",
    "build:wasm:test": "wasm-pack build --target nodejs --out-dir pkg-test --dev",
    "start": "npm run build:wasm && vite",
    "build": "npm run build:wasm && vite build",
    "serve": "vite preview",
    "test": "npm run build:wasm:test && vitest run",
    "test:watch": "vitest",
    "test:full": "npm run build:wasm:test && CARGO_MANIFEST_PATH=../Cargo.toml cargo full && vitest run",
    "coverage": "npm run build:wasm:test && vitest run --coverage",
    "test:e2e": "NO_PROXY=localhost,127.0.0.1 npm run build && NO_PROXY=localhost,127.0.0.1 playwright test"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "http-server": "^14.1.1",
    "jsdom": "^25.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^2.1.0"
  }
}
